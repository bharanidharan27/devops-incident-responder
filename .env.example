# === Core ===
ENV=dev
POLL_INTERVAL_SECONDS=10

# === API / UI ===
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000

# === DB ===
DB_FILE=dev.db
DB_URL=sqlite:///dev.db

# === Free-first AI ===
# Default path uses free hosted tiers when keys are present and rule-based fallback otherwise.
AI_ENABLED=true
ALLOW_PAID_PROVIDERS=false
LLM_MODEL=gemini/gemini-2.5-flash-lite
LLM_FALLBACK_MODELS=groq/qwen/qwen3-32b,ollama/gemma3
LLM_TIMEOUT_SECONDS=30

# Optional provider keys. Leave blank to use deterministic rule-based fallback.
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Optional local model fallback. Requires an Ollama server and OLLAMA_ENABLED=true.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434

# === RAG ===
VECTOR_BACKEND=chroma
RAG_COLLECTION_NAME=incident_playbooks
RAG_PERSIST_DIR=.chromadb
RAG_DATA_DIR=app/rag/data

# === Logs ===
LOGS_MODE=local
LOGS_LOCAL_ROOT=app/logs

# === CloudWatch (future optional integration) ===
USE_REAL_CLOUDWATCH=false
CLOUDWATCH_LOG_GROUP=/aws/lambda/demo
